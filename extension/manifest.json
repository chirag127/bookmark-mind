{
    "manifest_version": 3,
    "name": "BookmarkMind - AI Bookmark Organizer",
    "version": "1.1.0",
    "description": "AI-powered bookmark organizer. Bring your own key for 12 built-in OpenAI-compatible providers (Groq, Gemini, Cerebras, OpenRouter, Mistral, HuggingFace, Ollama, LM Studio, LiteLLM, DeepSeek, Novita, OpenAI) or add any custom endpoint. Automatically categorizes bookmarks into intelligent folders.",
    "permissions": [
        "bookmarks",
        "storage",
        "activeTab",
        "tabs",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "features/core/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "features/dashboard/dashboard.html",
        "default_title": "BookmarkMind - Organize Bookmarks",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "features/settings/settings.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "author": "BookmarkMind Team",
    "homepage_url": "https://github.com/chirag127/bookmark-mind-bs-ext"
}